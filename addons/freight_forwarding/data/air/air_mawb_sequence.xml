<odoo>
    <record id="seq_air_mawb" model="ir.sequence">
        <field name="name">MAWB No.</field>
        <field name="code">freight.air.mawb</field>
        <field name="prefix">JOB/MAWB/</field>
        <field name="suffix">/%(day)s%(month)s%(year)s</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_air_mawb_job" model="ir.sequence">
        <field name="name">MAWB Job No.</field>
        <field name="code">freight.air.mawb.job</field>
        <field name="prefix">JKT/AE/%(y)s/%(month)s/</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
</odoo>