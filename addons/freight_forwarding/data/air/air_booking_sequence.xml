<odoo>
    <record id="seq_air_booking" model="ir.sequence">
        <field name="name">Air Booking No.</field>
        <field name="code">freight.air.booking.no</field>
        <field name="prefix">WPC/BOOK/</field>
        <field name="suffix">/%(year)s</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_air_booking_job" model="ir.sequence">
        <field name="name">Air Booking Job No</field>
        <field name="code">freight.air.booking.job.no</field>
        <field name="prefix">JOB/BOOK/</field>
        <field name="suffix">/%(year)s</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
</odoo>