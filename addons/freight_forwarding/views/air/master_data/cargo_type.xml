<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_cargo_type_list" model="ir.ui.view">
        <field name="name">freight.cargo.type.list</field>
        <field name="model">freight.cargo.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_freight_cargo_type_form" model="ir.ui.view">
        <field name="name">freight.cargo.type.form</field>
        <field name="model">freight.cargo.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_cargo_type" model="ir.actions.act_window">
        <field name="name">Cargo Type</field>
        <field name="res_model">freight.cargo.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
