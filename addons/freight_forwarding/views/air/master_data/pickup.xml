<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_pickup_list" model="ir.ui.view">
        <field name="name">freight.pickup.list</field>
        <field name="model">freight.pickup</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="transportation_method"/>
                <field name="country_id"/>
                <field name="state_id"/>
            </list>
        </field>
    </record>

    <record id="view_freight_pickup_form" model="ir.ui.view">
        <field name="name">freight.pickup.form</field>
        <field name="model">freight.pickup</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="transportation_method"/>
                        <field name="country_id"/>
                        <field name="state_id"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_pickup" model="ir.actions.act_window">
        <field name="name">Pickup</field>
        <field name="res_model">freight.pickup</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
