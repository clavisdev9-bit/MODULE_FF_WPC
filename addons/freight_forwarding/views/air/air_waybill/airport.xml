<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_airport_list" model="ir.ui.view">
        <field name="name">freight.airport.list</field>
        <field name="model">freight.airport</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" />
                <field name="name" />
                <field name="country_id" />
            </list>
        </field>
    </record>

    <record id="view_freight_airport_form" model="ir.ui.view">
        <field name="name">freight.airport.form</field>
        <field name="model">freight.airport</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code" />
                        <field name="name" />
                        <field name="country_id" />
                        <field name="active" widget="boolean_toggle" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_airport" model="ir.actions.act_window">
        <field name="name">Airports</field>
        <field name="res_model">freight.airport</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>