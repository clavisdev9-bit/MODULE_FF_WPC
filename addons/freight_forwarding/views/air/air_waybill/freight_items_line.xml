<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_air_mawb_items_line_list" model="ir.ui.view">
        <field name="name">freight.air.mawb.items.line.list</field>
        <field name="model">freight.air.mawb.items.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="package_details_id" />
                <field name="article"/>
                <field name="type"/>
                <field name="cant"/>
                <field name="volume"/>
                <field name="gross_weight"/>
            </list>
        </field>
    </record>

    <record id="view_freight_air_mawb_items_line_form" model="ir.ui.view">
        <field name="name">freight.air.mawb.items.line.form</field>
        <field name="model">freight.air.mawb.items.line</field>
        <field name="arch" type="xml">
            <form string="MAWB Freight Items Line">
                <sheet>
                    <group>
                        <field name="package_details_id" />
                    </group>
                    
                    <group>
                        <group>
                            <field name="article"/>
                            <field name="type"/>
                            <field name="cant"/>
                        </group>
                        <group>
                            <field name="length"/>
                            <field name="width"/>
                            <field name="height"/>
                            <field name="volume"/>
                            <field name="gross_weight"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_air_mawb_items_line" model="ir.actions.act_window">
        <field name="name">MAWB Freight Items Line</field>
        <field name="res_model">freight.air.mawb.items.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
