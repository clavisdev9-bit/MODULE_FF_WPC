<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Receipt -->
    <record id="view_freight_air_waybill_transaction_receipt_list" model="ir.ui.view">
        <field name="name">freight.air.waybill.transaction.receipt.list</field>
        <field name="model">freight.air.waybill.transaction.receipt</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_freight_air_waybill_transaction_receipt_form" model="ir.ui.view">
        <field name="name">freight.air.waybill.transaction.receipt.form</field>
        <field name="model">freight.air.waybill.transaction.receipt</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_air_waybill_transaction_receipt" model="ir.actions.act_window">
        <field name="name">Receipt</field>
        <field name="res_model">freight.air.waybill.transaction.receipt</field>
