<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_freight_air_handling_information_form" model="ir.ui.view">
        <field name="name">freight.air.handling.information.form</field>
        <field name="model">freight.air.handling.information</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_freight_air_handling_information_list" model="ir.ui.view">
        <field name="name">freight.air.handling.information.list</field>
        <field name="model">freight.air.handling.information</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_freight_air_handling_information" model="ir.actions.act_window">
        <field name="name">Handling Information</field>
        <field name="res_model">freight.air.handling.information</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>