<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_airline_list" model="ir.ui.view">
        <field name="name">freight.airline.list</field>
        <field name="model">freight.airline</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="awb_prefix"/>
            </list>
        </field>
    </record>

    <record id="view_freight_airline_form" model="ir.ui.view">
        <field name="name">freight.airline.form</field>
        <field name="model">freight.airline</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="awb_prefix"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_airline" model="ir.actions.act_window">
        <field name="name">Airlines</field>
        <field name="res_model">freight.airline</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>