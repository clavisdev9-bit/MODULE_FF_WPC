<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_terms_conditions_list" model="ir.ui.view">
        <field name="name">freight.terms.conditions.list</field>
        <field name="model">freight.terms.conditions</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_freight_terms_conditions_form" model="ir.ui.view">
        <field name="name">freight.terms.conditions.form</field>
        <field name="model">freight.terms.conditions</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_terms_conditions" model="ir.actions.act_window">
        <field name="name">Terms and Conditions</field>
        <field name="res_model">freight.terms.conditions</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>