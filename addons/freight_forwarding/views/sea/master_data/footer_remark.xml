<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_footer_remark_list" model="ir.ui.view">
        <field name="name">freight.footer.remark.list</field>
        <field name="model">freight.footer.remark</field>
        <field name="arch" type="xml">
            <list>
                <field name="booking_remark"/>
                <field name="warehouse_remark"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_freight_footer_remark_form" model="ir.ui.view">
        <field name="name">freight.footer.remark.form</field>
        <field name="model">freight.footer.remark</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="booking_remark"/>
                        <field name="warehouse_remark"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_footer_remark" model="ir.actions.act_window">
        <field name="name">Footer/Remark</field>
        <field name="res_model">freight.footer.remark</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
