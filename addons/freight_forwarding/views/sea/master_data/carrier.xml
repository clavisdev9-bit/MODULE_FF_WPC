<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_carrier_list" model="ir.ui.view">
        <field name="name">freight.carrier.list</field>
        <field name="model">freight.carrier</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="scac_code"/>
            </list>
        </field>
    </record>

    <record id="view_freight_carrier_form" model="ir.ui.view">
        <field name="name">freight.carrier.form</field>
        <field name="model">freight.carrier</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="scac_code"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_carrier" model="ir.actions.act_window">
        <field name="name">Carrier</field>
        <field name="res_model">freight.carrier</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>