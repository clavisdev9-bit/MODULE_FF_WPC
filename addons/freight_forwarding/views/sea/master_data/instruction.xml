<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_freight_instruction_list" model="ir.ui.view">
        <field name="name">freight.instruction.list</field>
        <field name="model">freight.instruction</field>
        <field name="arch" type="xml">
            <list>
                <field name="instruction_type"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_freight_instruction_form" model="ir.ui.view">
        <field name="name">freight.instruction.form</field>
        <field name="model">freight.instruction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="instruction_type"/>
                        <field name="description"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_freight_instruction" model="ir.actions.act_window">
        <field name="name">Instruction</field>
        <field name="res_model">freight.instruction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
