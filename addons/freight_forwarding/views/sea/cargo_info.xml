<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sea_cargo_info_form_base" model="ir.ui.view">
        <field name="name">freight.sea.cargo.info.form.base</field>
        <field name="model">freight.sea.cargo.info.mixin</field>
        <field name="arch" type="xml">
            <form string="Sea Cargo Info">
                <sheet>
                    <group>
                        <field name="uom" widget="radio" options="{&quot;horizontal&quot;:true}" />
                    </group>

                    <group>
                        <group string="Box / Pallet / Load">
                            <field name="container_type_id" />
                            <field name="container_no" />
                            <field name="package_type_id" />
                            <field name="seal_no" />
                        </group>
                        <group string="Qty &amp; Type">
                            <field name="types_of_cargo" />
                            <field name="quantity" />
                        </group>
                    </group>

                    <group>
                        <group string="Dimension">
                            <field name="length" />
                            <field name="width" />
                            <field name="height" />
                        </group>
                        <group string="Weight &amp; Volume">
                            <field name="gross_weight" />
                            <field name="net_weight" />
                            <field name="volume_manual" />
                            <field name="volume" readonly="not volume_manual" />
                            <field name="total_volume" />
                        </group>
                    </group>

                    <group>
                        <group string="Environmental Condition">
                            <field name="harmonize" />
                            <field name="temperature" />
                            <field name="ventilation" />
                            <field name="humidity" />
                        </group>
                        <group string="Dangerous Goods">
                            <field name="has_dangerous_goods" />
                        </group>
                    </group>

                    <group name="dangerous_goods_group" invisible="has_dangerous_goods == False">
                        <group string="Regulatory Classification">
                            <field name="imdg_code" />
                            <field name="class_number" />
                            <field name="packing_group" />
                            <field name="a_number" />
                        </group>
                        <group string="Safety and Handling">
                            <field name="flash_point" />
                            <field name="material_description" />
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>
</odoo>
