<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Invoice Views -->
    <record id="view_sea_hbl_invoice_list" model="ir.ui.view">
        <field name="name">freight.sea.hbl.invoice.list</field>
        <field name="model">freight.sea.hbl.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="no_document" />
                <field name="date" />
                <field name="invoice_reference" />
            </list>
        </field>
    </record>

    <record id="view_sea_hbl_invoice_form" model="ir.ui.view">
        <field name="name">freight.sea.hbl.invoice.form</field>
        <field name="model">freight.sea.hbl.invoice</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="hbl_id" />
                        <field name="no_document" />
                        <field name="description" />
                    </group>
                    <group>
                        <field name="date" />
                        <field name="document" filename="document_filename" />
                        <field name="document_filename" invisible="1" />
                    </group>
                    <group>
                        <field name="invoice_reference" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

