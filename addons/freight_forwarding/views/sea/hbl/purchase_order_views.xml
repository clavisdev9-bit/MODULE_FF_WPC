<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sea_hbl_purchase_order_list" model="ir.ui.view">
        <field name="name">freight.sea.hbl.purchase.order.list</field>
        <field name="model">freight.sea.hbl.purchase.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="purchase_order_id" />
                <field name="vendor" />
                <field name="currency" />
                <field name="amount" sum="Total" />
            </list>
        </field>
    </record>

    <record id="view_sea_hbl_purchase_order_form" model="ir.ui.view">
        <field name="name">freight.sea.hbl.purchase.order.form</field>
        <field name="model">freight.sea.hbl.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Sea Jobsheet Purchase Order">
                <sheet>
                    <group>
                        <field name="hbl_id" />
                    </group>
                    <group>
                        <field name="purchase_order_id" />
                        <field name="vendor" />
                        <field name="currency" />
                        <field name="amount" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>