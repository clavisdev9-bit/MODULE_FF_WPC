<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sea_hbl_list" model="ir.ui.view">
        <field name="name">freight.sea.hbl.list</field>
        <field name="model">freight.sea.hbl</field>
        <field name="arch" type="xml">
            <list>
                <field name="hbl_no"/>
                <field name="freight_type"/>
                <field name="container_type"/>
                <field name="quotation_id"/>
                <field name="booking_id"/>
                <field name="customer_id"/>
                <field name="job_no"/>
                <field name="job_date"/>
            </list>
        </field>
    </record>

    <record id="view_sea_hbl_form" model="ir.ui.view">
        <field name="name">freight.sea.hbl.form</field>
        <field name="model">freight.sea.hbl</field>
        <field name="arch" type="xml">
            <form string="Sea Jobsheet">
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_quotation"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Quotation</span>
                            </div>
                        </button>
                        <button name="action_view_booking"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-ship"
                            invisible="booking_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Booking</span>
                            </div>
                        </button>
                    </div>
                    <h1>
                        <field name="hbl_no" readonly="1" />
                    </h1>
                    <group string="Header Information">
                        <group>
                            <field name="freight_type"/>
                            <field name="container_type"/>
                            <field name="quotation_id"/>
                            <field name="booking_id"/>
                            <field name="job_no" readonly="1"/>
                            <field name="job_date"/>
                        </group>
                        <group>
                            <field name="job_city_id"/>
                            <field name="master_job_no"/>
                            <field name="original_bl_no"/>
                            <field name="shipment_type"/>
                            <field name="bl_surrendered"/>
                        </group>
                    </group>

                    <group string="Customer &amp; Sales">
                        <group>
                            <field name="customer_id"/>
                            <field name="customer_ref" readonly="1"/>
                            <field name="shipper_id"/>
                            <field name="shipper_address" readonly="1"/>
                        </group>
                        <group>
                            <field name="consignee_id" />
                            <field name="consignee_address" readonly="1" />
                            <field name="term_payment"/>
                            <field name="salesman_id"/>
                            <field name="export_sales_team_id"/>
                        </group>
                    </group>

                    <group>
                        <group string="Notify Party">
                            <field name="notify_id" />
                            <field name="notify_address" readonly="1" />
                        </group>
                        <group string="Delivery &amp; Freight">
                            <field name="delivery_agent_id" />
                            <field name="delivery_agent_address" readonly="1" />
                            <field name="freight" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Shipment Info">
                            <field name="shipment_info_ids" nolabel="1"/>
                        </page>
                        <page string="Vessel Details">
                            <field name="vessel_details_ids" nolabel="1"/>
                        </page>
                        <page string="Cargo Info">
                            <field name="cargo_info_ids" />
                        </page>
                        <page string="Custom Permit">
                            <field name="custom_permit_ids" nolabel="1">
                                <list>
                                    <field name="no_document" />
                                    <field name="date" />
                                    <field name="status" />
                                </list>
                            </field>
                        </page>
                        <page string="Purchase Order">
                            <field name="purchase_order_ids" nolabel="1"/>
                        </page>
                        <page string="Sales Order">
                            <field name="sales_order_ids" nolabel="1"/>
                        </page>
                        <page string="Tax Refund Doc">
                            <field name="tax_refund_doc_ids" nolabel="1"/>
                        </page>
                        <page string="Document List">
                            <notebook>
                                <page string="Invoice">
                                    <field name="invoice_ids" nolabel="1"/>
                                </page>
                                <page string="Debit Note">
                                    <field name="debit_note_ids" nolabel="1"/>
                                </page>
                                <page string="Credit Note">
                                    <field name="credit_note_ids" nolabel="1"/>
                                </page>
                                <page string="Provision Cost">
                                    <field name="provision_cost_ids" nolabel="1"/>
                                </page>
                                <page string="Vendor Invoice">
                                    <field name="vendor_invoice_ids" nolabel="1"/>
                                </page>
                                <page string="Vendor Debit Note">
                                    <field name="vendor_debit_note_ids" nolabel="1"/>
                                </page>
                                <page string="Vendor Credit Note">
                                    <field name="vendor_credit_note_ids" nolabel="1"/>
                                </page>
                                <page string="Cash Purchase">
                                    <field name="cash_purchase_ids" nolabel="1"/>
                                </page>
                            </notebook>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sea_hbl_search" model="ir.ui.view">
        <field name="name">freight.sea.hbl.search</field>
        <field name="model">freight.sea.hbl</field>
        <field name="arch" type="xml">
            <search>
                <field name="hbl_no" string="Jobsheet No."/>
                <field name="booking_id"/>
                <field name="customer_id"/>
                <field name="freight_type"/>
                <field name="container_type"/>
                <separator/>
                <filter name="filter_import" string="Import" domain="[('freight_type', '=', 'import')]"/>
                <filter name="filter_export" string="Export" domain="[('freight_type', '=', 'export')]"/>
                <filter name="filter_fcl" string="FCL" domain="[('container_type', '=', 'fcl')]"/>
                <filter name="filter_lcl" string="LCL" domain="[('container_type', '=', 'lcl')]"/>
                <filter name="filter_consol" string="Consol" domain="[('container_type', '=', 'consol')]"/>
            </search>
        </field>
    </record>

    <record id="action_sea_hbl" model="ir.actions.act_window">
        <field name="name">Sea Jobsheet</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
    </record>

    <record id="action_sea_hbl_import_fcl" model="ir.actions.act_window">
        <field name="name">Import Jobsheet FCL</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'import'), ('container_type', '=', 'fcl')]</field>
    </record>

    <record id="action_sea_hbl_import_lcl" model="ir.actions.act_window">
        <field name="name">Import Jobsheet LCL</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'import'), ('container_type', '=', 'lcl')]</field>
    </record>

    <record id="action_sea_hbl_import_consol" model="ir.actions.act_window">
        <field name="name">Import Jobsheet Consol</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'import'), ('container_type', '=', 'consol')]</field>
    </record>

    <record id="action_sea_hbl_export_fcl" model="ir.actions.act_window">
        <field name="name">Export Jobsheet FCL</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'export'), ('container_type', '=', 'fcl')]</field>
    </record>

    <record id="action_sea_hbl_export_lcl" model="ir.actions.act_window">
        <field name="name">Export Jobsheet LCL</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'export'), ('container_type', '=', 'lcl')]</field>
    </record>

    <record id="action_sea_hbl_export_consol" model="ir.actions.act_window">
        <field name="name">Export Jobsheet Consol</field>
        <field name="res_model">freight.sea.hbl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sea_hbl_search"/>
        <field name="domain">[('freight_type', '=', 'export'), ('container_type', '=', 'consol')]</field>
    </record>
</odoo>
