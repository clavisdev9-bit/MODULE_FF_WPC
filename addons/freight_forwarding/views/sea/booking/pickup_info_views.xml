<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_sea_booking_pickup_info_list" model="ir.ui.view">
            <field name="name">Sea Booking Pickup Info List</field>
            <field name="model">freight.sea.booking.pickup.info</field>
            <field name="arch" type="xml">
                <list>
                    <field name="type" />
                    <field name="type_of_load" />
                    <field name="loading_port" />
                    <field name="discharge_port" />
                </list>
            </field>
        </record>

        <record id="view_sea_booking_pickup_info_form" model="ir.ui.view">
            <field name="name">Sea Booking Pickup Info Form</field>
            <field name="model">freight.sea.booking.pickup.info</field>
            <field name="arch" type="xml">
                <form>
                    <group string="Route Charges">
                        <field name="type" />
                        <field name="pickup" invisible="type == 'prior_transport'" />
                        <field name="receive_from_id" invisible="pickup == False"/>
                        <field name="warehouse_id" invisible="pickup == False" />
                        <field name="currency_id" />
                        <div class="o_form_label fw-bold">Positions</div>
                        <div class="o_row" name="studio_div_478fb8">
                            <field name="type_of_load" nolabel="1" />
                            <field name="position" nolabel="1" widget="monetary"
                                options="{'currency_field':'currency_id', 'no_symbol':false}"
                                invisible="type_of_load != 'paid'" />
                        </div>
                    </group>

                    <group>
                        <group string="Address Type">
                            <field name="address" widget="radio" options="{'horizontal': True}"/>
                        </group>
                        <group string="Estimated Time">
                            <field name="estimate_pickup" />
                            <field name="estimate_arrival" />
                        </group>
                    </group>

                    <group string="Location Details">
                        <field name="loading_port" />
                        <field name="discharge_port" />
                    </group>

                    <group string="Address">
                        <group>
                            <span>Source</span>
                            <div class="o_address_format">
                                <field name="source_street" placeholder="Street..."
                                    class="o_address_street" />
                                <field name="source_street2" placeholder="Street 2..."
                                    class="o_address_street" />
                                <field name="source_city" placeholder="City"
                                    class="o_address_city" />
                                <field name="source_state_id" placeholder="State"
                                    class="o_address_state" />
                                <field name="source_zip" placeholder="ZIP"
                                    class="o_address_zip" />
                                <field name="source_country_id" placeholder="Country"
                                    class="o_address_country" />
                            </div>
                        </group>
                        <group>
                            <span>Destination</span>
                            <div class="o_address_format" name="studio_div_8cbbbf">
                                <field name="destination_street" placeholder="Street..."
                                    class="o_address_street" />
                                <field name="destination_street2" placeholder="Street 2..."
                                    class="o_address_street" />
                                <field name="destination_city" placeholder="City"
                                    class="o_address_city" />
                                <field name="destination_state_id" placeholder="State"
                                    class="o_address_state" />
                                <field name="destination_zip" placeholder="ZIP"
                                    class="o_address_zip" />
                                <field name="destination_country_id" placeholder="Country"
                                    class="o_address_country" />
                            </div>
                        </group>
                    </group>

                    <group string="Vehicle Details">
                        <field name="bouquet_id" />
                        <field name="obl_no" />
                        <field name="trip_no" />
                    </group>
                </form>
            </field>
        </record>
    </data>
</odoo>
