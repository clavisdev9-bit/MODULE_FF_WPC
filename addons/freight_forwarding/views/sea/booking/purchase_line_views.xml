<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sea_booking_purchase_order_list" model="ir.ui.view">
            <field name="name">Sea Booking Purchase Order List</field>
            <field name="model">freight.sea.booking.purchase.order</field>
            <field name="arch" type="xml">
                <list>
                    <field name="purchase_order_id" />
                    <field name="vendor" />
                    <field name="currency" />
                    <field name="amount" sum="Total" />
                </list>
            </field>
        </record>

        <record id="view_sea_booking_purchase_order_form" model="ir.ui.view">
            <field name="name">Sea Booking Purchase Order Form</field>
            <field name="model">freight.sea.booking.purchase.order</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="purchase_order_id" />
                            <field name="vendor" />
                            <field name="currency" />
                            <field name="amount" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>