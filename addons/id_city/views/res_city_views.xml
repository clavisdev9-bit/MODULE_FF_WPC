<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_city_view_search" model="ir.ui.view">
            <field name="name">res.city.search</field>
            <field name="model">res.city</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="state_id"/>
                    <!-- <field name="subdistrict_ids"/> -->
                </search>
            </field>
        </record>

        <record id="res_city_view_list" model="ir.ui.view">
            <field name="name">res.city.list</field>
            <field name="model">res.city</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="state_id"/>
                    <!-- <field name="subdistrict_ids"/> -->
                </list>
            </field>
        </record>

        <record id="res_city_view_form" model="ir.ui.view">
            <field name="name">res.city.form</field>
            <field name="model">res.city</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="state_id"/>
                            </group>
                        </group>
                        <!-- <notebook>
                            <page string="Subdistricts">
                                <field name="subdistrict_ids"/>
                            </page>
                        </notebook> -->
                    </sheet>
                </form>
            </field>
        </record>

        <record id="res_city_action" model="ir.actions.act_window">
            <field name="name">City</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.city</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="res_city_menu" parent="contacts.menu_localisation" action="res_city_action" sequence="3"/>

    </data>
</odoo>
