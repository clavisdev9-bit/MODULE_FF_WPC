<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_subdistrict_view_search" model="ir.ui.view">
            <field name="name">res.subdistrict.search</field>
            <field name="model">res.subdistrict</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="city_id"/>
                    <field name="village_ids"/>
                </search>
            </field>
        </record>

        <record id="res_subdistrict_view_list" model="ir.ui.view">
            <field name="name">res.subdistrict.list</field>
            <field name="model">res.subdistrict</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="city_id"/>
                    <field name="village_ids"/>
                </list>
            </field>
        </record>

        <record id="res_subdistrict_view_form" model="ir.ui.view">
            <field name="name">res.subdistrict.form</field>
            <field name="model">res.subdistrict</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="city_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Desa / Kelurahan">
                                <field name="village_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="res_subdistrict_action" model="ir.actions.act_window">
            <field name="name">Kecamatan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.subdistrict</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="res_subdistrict_menu" parent="contacts.menu_localisation" action="res_subdistrict_action" sequence="4"/>

    </data>
</odoo>
