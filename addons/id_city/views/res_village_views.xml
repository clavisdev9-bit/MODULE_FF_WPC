<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_village_view_search" model="ir.ui.view">
            <field name="name">res.village.search</field>
            <field name="model">res.village</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="subdistrict_id"/>
                    <field name="zip"/>
                </search>
            </field>
        </record>

        <record id="res_village_view_list" model="ir.ui.view">
            <field name="name">res.village.list</field>
            <field name="model">res.village</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="subdistrict_id"/>
                    <field name="zip"/>
                </list>
            </field>
        </record>

        <record id="res_village_view_form" model="ir.ui.view">
            <field name="name">res.village.form</field>
            <field name="model">res.village</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="zip"/>
                            </group>
                            <group>
                                <field name="subdistrict_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="res_village_action" model="ir.actions.act_window">
            <field name="name">Desa / Kelurahan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.village</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="res_village_menu" parent="contacts.menu_localisation" action="res_village_action" sequence="5"/>

    </data>
</odoo>
